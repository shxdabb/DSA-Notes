class Solution(object):
    
    #we will be adding the height returned by dfs into res
    def diameterOfBinaryTree(self, root):
        self.res = 0
        """
        :type root: Optional[TreeNode]
        :rtype: int
        """
        def dfs(curr): #this functions returns the height
            if not curr:
                return 0
            left = dfs(curr.left)
            right = dfs(curr.right)
            self.res = max(self.res,left+right)

            return 1 + max(left,right)
        dfs(root)
        return self.res


            

        



